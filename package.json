{
  "name": "app-template",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:server\" \"pnpm dev:metro\"",
    "dev:server": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "dev:metro": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 npx expo start --web --port ${EXPO_PORT:-8081}",
    "dev:expo": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 npx expo start --port ${EXPO_PORT:-8081}",
    "dev:expo:tunnel": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 npx expo start --tunnel --port ${EXPO_PORT:-8081}",
    "build": "esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "lint": "expo lint",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "android": "expo run:android",
    "android:log": "bash scripts/android-crash-log.sh",
    "ios": "expo run:ios",
    "qr": "node scripts/generate_qr.mjs"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.9",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "~7.15.9",
    "@react-navigation/elements": "~2.9.14",
    "@react-navigation/native": "7.2.2",
    "@tanstack/react-query": "^5.90.12",
    "@trpc/client": "11.7.2",
    "@trpc/react-query": "11.7.2",
    "@trpc/server": "11.7.2",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^9.4.5",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.7",
    "expo": "~55.0.10",
    "expo-asset": "~55.0.12",
    "expo-audio": "~55.0.10",
    "expo-auth-session": "~55.0.11",
    "expo-build-properties": "~55.0.10",
    "expo-constants": "~55.0.10",
    "expo-crypto": "~55.0.11",
    "expo-font": "~55.0.5",
    "expo-haptics": "~55.0.10",
    "expo-image": "~55.0.7",
    "expo-keep-awake": "~55.0.5",
    "expo-linking": "~55.0.10",
    "expo-notifications": "~55.0.15",
    "expo-router": "~55.0.9",
    "expo-secure-store": "~55.0.10",
    "expo-splash-screen": "~55.0.14",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.6",
    "expo-system-ui": "~55.0.12",
    "expo-video": "~55.0.12",
    "expo-web-browser": "~55.0.11",
    "express": "^4.22.1",
    "google-auth-library": "^9.14.2",
    "jose": "6.1.0",
    "mysql2": "^3.16.0",
    "nativewind": "^4.2.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "superjson": "^1.13.3",
    "tailwind-merge": "^2.6.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie": "^0.6.0",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.2.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.8",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~55.0.0",
    "prettier": "^3.7.4",
    "qrcode": "^1.5.4",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@9.12.0",
  "pnpm": {
    "overrides": {
      "@react-navigation/native": "7.2.2"
    }
  }
}
